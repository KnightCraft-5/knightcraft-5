# ---- Mod/shader jars ----
# Resolved via packwiz metadata (.pw.toml), downloaded on install — not stored.
# Exception: jars CurseForge blocks from API redistribution must be bundled.
mods/*.jar
!mods/Dungeon-Realm-1.20.1-1.1.7.jar
!mods/tl_skin_cape_forge_1.20_1.20.1-1.32.jar

# ---- Runtime / instance data (from a CurseForge export or a live instance) ----
logs/
crash-reports/
screenshots/
saves/
world/
backups/
journeymap/
local/
blueprints/
*.log
*.log.gz
hs_err_pid*.log

# ---- Personal / sensitive instance files ----
servers.dat
servers.dat_old
usercache.json
.sl_password
*.local.properties

# ---- Caches & packwiz-installer artifacts ----
.cache/
.packwiz-cache/
packwiz-installer*.jar
.packwiz-installer*

# ---- Runtime files the game writes into the pack root (dev = .minecraft) ----
optionsof.txt
optionsshaders.txt
hotbar.nbt
realms_persistence.json
.mixin.out/

# ---- Build artifacts (exported packs in repo root) ----
# Note: resourcepacks/*.zip stay tracked — only root-level export zips are ignored.
/*.zip

# ---- OS / editor junk ----
.DS_Store
Thumbs.db
desktop.ini
*~
*.swp
.idea/
.vscode/
